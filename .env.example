# SiteSift environment. Copy to .env and adjust:  cp .env.example .env
#
# Every value below has a working default in code. The foundation runs with no
# .env file at all, and with no AI keys.

# --- Database ---------------------------------------------------------------
# Local default (no server required):
DATABASE_URL=sqlite:///./sitesift.db
# docker compose uses Postgres instead:
# DATABASE_URL=postgresql+psycopg://sitesift:sitesift@localhost:5432/sitesift

# --- Ports ------------------------------------------------------------------
# Change these per worktree so several SiteSift checkouts can run at once.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend ---------------------------------------------------------------
# Read by the browser, so it must point at the backend's host-visible URL and
# must match BACKEND_PORT.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Serve recorded fixtures instead of the real backend. For isolated frontend work
# only: the integrated app runs against the real API and never falls back to mock
# data when a request fails.
NEXT_PUBLIC_USE_MOCK_API=false

# --- AI providers (optional) ------------------------------------------------
# auto = use OpenAI when OPENAI_API_KEY is set, otherwise local heuristic fallback.
# Use heuristic for offline demos/tests, or openai to require model-backed extraction.
DOCUMENT_EXTRACTOR_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_DOCUMENT_MODEL=gpt-4.1-mini
OPENAI_REQUEST_TIMEOUT_SECONDS=45
ANTHROPIC_API_KEY=
